{
	"manifest_version": 3,
	"name": "AI浏览器助手",
	"version": "1.0.0",
	"description": "智能AI助手，提供对话、网页分析和自动化操作功能",
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"action": {
		"default_title": "AI浏览器助手"
	},
	"background": {
		"service_worker": "src/background/index.js"
	},
	"side_panel": {
		"default_path": "src/sidePanel/index.html"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["src/content/index.js"],
			"run_at": "document_idle"
		}
	],
	"permissions": ["storage", "activeTab", "sidePanel", "scripting", "history", "tabs", "webRequest", "contextMenus"],
	"host_permissions": ["<all_urls>"],
	"web_accessible_resources": [
		{
			"resources": ["assets/*"],
			"matches": ["<all_urls>"]
		}
	]
}
